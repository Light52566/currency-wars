# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development                  # development | production
SECRET_KEY=change-me-to-a-random-secret

# ─── Backend (FastAPI) ───────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (MVP default)
DATABASE_URL=sqlite:///./currency_wars.db

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/currency_wars

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Currency Wars

# ─── Online Data Adapters ────────────────────────────────────────────────────
# yfinance does not require an API key.
# Alpha Vantage (optional fallback for stocks/forex)
ALPHA_VANTAGE_API_KEY=

# CoinGecko (crypto — free tier, no key required; Pro key for higher rate limits)
COINGECKO_API_KEY=

# exchangerate.host (forex — free tier available)
EXCHANGERATE_API_KEY=

# ─── Offline Data ────────────────────────────────────────────────────────────
# Path to directory containing historical OHLCV CSV/JSON files
OFFLINE_DATA_DIR=./data

# ─── Price Snapshot Interval ────────────────────────────────────────────────
PRICE_SNAPSHOT_INTERVAL_SECONDS=60

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
